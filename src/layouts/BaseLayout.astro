---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>

        <style is:global>
            :root {
                --bg: #f6efe6;
                --surface: #fffaf4;
                --surface-2: #f2e7d8;
                --text: #2f261f;
                --muted: #74685b;
                --olive: #66724a;
                --terracotta: #c86e4b;
                --terracotta-dark: #a85839;
                --border: #e7d8c6;
                --shadow: 0 10px 30px rgba(80, 53, 33, 0.08);
                --radius-lg: 24px;
                --radius-md: 18px;
                --max-width: 1120px;
            }

            * {
                box-sizing: border-box;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                margin: 0;
                font-family: Georgia, "Times New Roman", serif;
                background:
                    radial-gradient(
                        circle at top left,
                        rgba(255, 255, 255, 0.55),
                        transparent 28%
                    ),
                    linear-gradient(to bottom, #f9f4ec, #f6efe6);
                color: var(--text);
                line-height: 1.65;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            img {
                max-width: 100%;
                display: block;
            }

            .site-shell {
                max-width: var(--max-width);
                margin: 0 auto;
                padding: 2rem 1.25rem 4rem;
            }

            .site-header {
                display: flex;
                align-items: flex-end;
                justify-content: space-between;
                gap: 1rem;
                padding: 1rem 0 2.25rem;
            }

            .site-brand {
                display: inline-block;
            }

            .site-title {
                margin: 0;
                font-size: clamp(2.3rem, 5vw, 4rem);
                line-height: 0.95;
                letter-spacing: -0.04em;
            }

            .site-subtitle {
                margin: 0.7rem 0 0;
                max-width: 42rem;
                color: var(--muted);
                font-size: 1.05rem;
            }

            .eyebrow {
                display: inline-block;
                margin-bottom: 0.75rem;
                color: var(--terracotta);
                font-size: 0.8rem;
                font-weight: 700;
                letter-spacing: 0.14em;
                text-transform: uppercase;
            }

            .card {
                background: rgba(255, 250, 244, 0.92);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow);
            }

            .section-card {
                padding: 1.5rem;
            }

            .tag-list {
                list-style: none;
                padding: 0;
                margin: 0;
                display: flex;
                flex-wrap: wrap;
                gap: 0.55rem;
            }

            .tag {
                display: inline-flex;
                align-items: center;
                padding: 0.42rem 0.8rem;
                border-radius: 999px;
                background: var(--surface-2);
                color: var(--terracotta-dark);
                font-size: 0.9rem;
                line-height: 1;
            }

            .muted {
                color: var(--muted);
            }

            .button-link {
                display: inline-flex;
                align-items: center;
                gap: 0.45rem;
                padding: 0.8rem 1rem;
                border: 1px solid var(--border);
                border-radius: 999px;
                background: rgba(255, 250, 244, 0.8);
                color: var(--olive);
                font-size: 0.95rem;
                transition:
                    transform 0.18s ease,
                    border-color 0.18s ease,
                    background 0.18s ease;
            }

            .button-link:hover {
                transform: translateY(-1px);
                border-color: #d9c4aa;
                background: #fffaf4;
            }

            .page-title {
                margin: 0;
                font-size: clamp(2rem, 5vw, 3.4rem);
                line-height: 1.02;
                letter-spacing: -0.04em;
            }

            .page-intro {
                margin: 0.75rem 0 0;
                color: var(--muted);
                font-size: 1.05rem;
                max-width: 42rem;
            }

            .recipe-grid {
                list-style: none;
                padding: 0;
                margin: 1.5rem 0 0;
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
                gap: 1.2rem;
            }

            .recipe-card {
                position: relative;
                overflow: hidden;
                padding: 1.25rem;
                transition:
                    transform 0.2s ease,
                    box-shadow 0.2s ease,
                    border-color 0.2s ease;
            }

            .recipe-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 18px 40px rgba(80, 53, 33, 0.12);
                border-color: #dcc8b2;
            }

            .recipe-card::before {
                content: "";
                position: absolute;
                inset: 0 auto auto 0;
                width: 100%;
                height: 5px;
                background: linear-gradient(
                    90deg,
                    var(--terracotta),
                    #d9a25f,
                    var(--olive)
                );
                opacity: 0.95;
            }

            .recipe-card-title {
                margin: 0.2rem 0 0.5rem;
                font-size: 1.45rem;
                line-height: 1.15;
            }

            .recipe-card-desc {
                margin: 0 0 1rem;
                color: var(--muted);
            }

            .recipe-meta {
                display: flex;
                flex-wrap: wrap;
                gap: 0.6rem;
                margin: 0 0 1rem;
            }

            .recipe-meta-chip {
                padding: 0.45rem 0.7rem;
                border-radius: 999px;
                background: rgba(242, 231, 216, 0.7);
                color: var(--olive);
                font-size: 0.9rem;
            }

            .recipe-hero {
                padding: 1.75rem;
            }

            .recipe-hero-top {
                display: flex;
                justify-content: space-between;
                gap: 1rem;
                align-items: start;
            }

            .recipe-body {
                display: grid;
                grid-template-columns: 280px 1fr;
                gap: 1.25rem;
                margin-top: 1.25rem;
            }

            .recipe-sidebar,
            .recipe-content {
                padding: 1.4rem;
            }

            .recipe-sidebar h2,
            .recipe-content h2 {
                margin-top: 0;
                margin-bottom: 0.9rem;
                font-size: 1.2rem;
            }

            .recipe-content :where(h2, h3) {
                margin-top: 1.6rem;
                margin-bottom: 0.7rem;
                font-size: 1.2rem;
            }

            .recipe-content :where(p, li) {
                font-size: 1.02rem;
            }

            .recipe-content ul,
            .recipe-content ol {
                padding-left: 1.2rem;
            }

            .recipe-sidebar .recipe-meta {
                margin-bottom: 1.2rem;
                gap: 0.7rem;
            }

            .recipe-sidebar .recipe-meta-chip {
                display: block;
                width: fit-content;
            }

            .recipe-section-label {
                margin: 1.25rem 0 0.7rem;
                color: var(--terracotta);
                font-size: 0.8rem;
                font-weight: 700;
                letter-spacing: 0.12em;
                text-transform: uppercase;
            }

            @media (max-width: 800px) {
                .site-header {
                    align-items: flex-start;
                    flex-direction: column;
                }

                .recipe-body {
                    grid-template-columns: 1fr;
                }

                .recipe-hero,
                .recipe-sidebar,
                .recipe-content,
                .section-card,
                .recipe-card {
                    padding: 1.15rem;
                }
            }
        </style>
    </head>
    <body>
        <div class="site-shell">
            <header class="site-header">
                <div>
                    <span class="eyebrow">Elfira's Kitchen</span>
                    <a class="site-brand" href={import.meta.env.BASE_URL}> </a>
                    <p class="site-subtitle">
                        A cozy collection of warm, healthy, and cozy recipes.
                    </p>
                </div>
            </header>

            <slot />
        </div>
    </body>
</html>
